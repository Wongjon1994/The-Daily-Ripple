# Copy this file to .env and fill in values

# Postgres connection string from Neon or Supabase (REQUIRED).
# Neon:     postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DB?sslmode=require
# Supabase: postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# For a local Postgres without TLS, append ?sslmode=disable
DATABASE_URL=

# API key to protect the brief publish endpoint (n8n uses this)
# Set to any strong random string, e.g.: openssl rand -hex 32
PUBLISH_API_KEY=

# Alpha Vantage API key — fallback source for US 10Y yield only (its BRENT and
# TREASURY_YIELD endpoints lag; Brent/Gold now come from Twelve Data). Free tier
# ~5/min, 25/day.
ALPHAVANTAGE_API_KEY=

# Twelve Data API key — equity indices, FX, and now Brent (XBR/USD) + Gold
# (XAU/USD) commodity CFDs. Free tier ~8/min, 800/day.
TWELVEDATA_API_KEY=

# FRED (St. Louis Fed) API key — fresh daily US 10Y yield (DGS10). Free key from
# fredaccount.stlouisfed.org. Without it, US 10Y falls back to (laggy) Alpha Vantage.
FRED_API_KEY=

# Tavily API key — web search for the weekly signal realisation sweep (Trends
# Part 2). Free tier (1,000 searches/month) covers the cadence. Without it, the
# Sunday /api/realise sweep runs the expiry pass only and skips web checks.
TAVILY_API_KEY=

# Anthropic API key — LLM verdict (claude-haiku-4-5) for signal realisation.
# Without it, the realisation sweep skips the LLM check (expiry pass still runs).
ANTHROPIC_API_KEY=

# App title (default: The Daily Ripple)
APP_TITLE=The Daily Ripple

# Server port (default: 3001)
PORT=3001
