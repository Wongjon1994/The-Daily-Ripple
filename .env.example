# Copy this file to .env and fill in values

# Postgres connection string from Neon or Supabase (REQUIRED).
# Neon:     postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DB?sslmode=require
# Supabase: postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# For a local Postgres without TLS, append ?sslmode=disable
DATABASE_URL=

# API key to protect the brief publish endpoint (n8n uses this)
# Set to any strong random string, e.g.: openssl rand -hex 32
PUBLISH_API_KEY=

# Alpha Vantage API key — market data for Brent, Gold, 10Y yield, FX pairs.
# Free tier is rate-limited (~5/min, 25/day); the refresh job staggers its calls.
ALPHAVANTAGE_API_KEY=

# Twelve Data API key — equity indices (S&P 500, Dow, STI, Nikkei, Hang Seng,
# KOSPI). Free tier ~8/min, 800/day. Yahoo/Stooq are blocked from the server.
TWELVEDATA_API_KEY=

# IPRoyal residential proxy for the /api/markets Yahoo fetch (Yahoo blocks the
# datacenter IP; CORS blocks the browser). Full URL: http://user:pass@host:port
IPROYAL_PROXY=

# App title (default: The Daily Ripple)
APP_TITLE=The Daily Ripple

# Server port (default: 3001)
PORT=3001
